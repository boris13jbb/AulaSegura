# AulaSegura environment variables
# .NET reads these values from the process environment. This file is a reference;
# load it with your preferred tooling or set the variables in Windows.

# Shared SQLite database used by the WPF app and the Windows service.
ConnectionStrings__DefaultConnection=Data Source=%PROGRAMDATA%\AulaSegura\aulasegura.db

# Set to true only after backing up the database and accepting data recreation.
Database__RecreateWhenSchemaIsIncomplete=false

# Initial administrator seed. Do not commit real passwords.
SeedAdmin__Username=admin
SeedAdmin__Password=change-me-before-first-run
SeedAdmin__Email=admin@aulasegura.local
SeedAdmin__FullName=Administrador Principal

# Worker service behavior.
AppSettings__CheckBlockingRulesIntervalSeconds=60
AppSettings__BlockingPagePort=8080
AppSettings__BackupEnabled=true
AppSettings__BackupRetentionDays=30
