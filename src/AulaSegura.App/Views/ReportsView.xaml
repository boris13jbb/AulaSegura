<UserControl x:Class="AulaSegura.App.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#9C27B0" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Back Button -->
                <Button Grid.Column="0"
                        Content="← Volver"
                        Command="{Binding GoBackCommand}"
                        Background="Transparent"
                        Foreground="White"
                        FontWeight="Bold"
                        Padding="12,8"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="14"
                        Margin="0,0,15,0"/>
                
                <StackPanel Grid.Column="1">
                    <TextBlock Text="📊 Reportes y Estadísticas" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Genere y exporte reportes de actividad de bloqueo" FontSize="14" Foreground="#F3E5F5" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="⚙️ Generar Reporte" FontSize="16" FontWeight="Bold" Foreground="#424242" Margin="0,0,0,15"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Fecha Inicio:" FontSize="12" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding StartDate}" Padding="8,6"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fecha Fin:" FontSize="12" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding EndDate}" Padding="8,6"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Tipo de Reporte:" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox SelectedItem="{Binding SelectedReportType}" Padding="8,6">
                            <ComboBoxItem Content="Resumen" Tag="Summary"/>
                            <ComboBoxItem Content="Detallado" Tag="Detailed"/>
                        </ComboBox>
                    </StackPanel>
                    <Button Grid.Column="6" Content="Generar" Command="{Binding GenerateReportCommand}" Background="#9C27B0" Foreground="White" Padding="20,8" BorderThickness="0" Cursor="Hand" FontSize="13" VerticalAlignment="Bottom"/>
                </Grid>
            </StackPanel>
        </Border>
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="📈 Estadísticas del Reporte" FontSize="16" FontWeight="Bold" Foreground="#424242"/>
                    <Button Content="📥 Exportar CSV" Command="{Binding ExportReportCommand}" Background="#4CAF50" Foreground="White" Padding="15,6" BorderThickness="0" Cursor="Hand" FontSize="12" Margin="20,0,0,0"/>
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#F5F5F5" Padding="15" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Bloqueos Totales" FontSize="12" Foreground="#757575"/>
                            <TextBlock Text="{Binding TotalBlocks}" FontSize="32" FontWeight="Bold" Foreground="#F44336" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#F5F5F5" Padding="15" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Violaciones" FontSize="12" Foreground="#757575"/>
                            <TextBlock Text="{Binding TotalViolations}" FontSize="32" FontWeight="Bold" Foreground="#FF9800" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#F5F5F5" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Sitio Más Bloqueado" FontSize="12" Foreground="#757575"/>
                            <TextBlock Text="{Binding TopBlockedSite}" FontSize="14" FontWeight="SemiBold" Foreground="#2196F3" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
        <Border Grid.Row="3" Background="#F3E5F5" CornerRadius="4" Padding="15" Margin="0,20,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#7B1FA2"/>
        </Border>
    </Grid>
</UserControl>
