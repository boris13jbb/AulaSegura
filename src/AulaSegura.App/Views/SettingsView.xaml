<UserControl x:Class="AulaSegura.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800">
    <ScrollViewer Margin="20">
        <StackPanel>
            <!-- Back Button -->
            <Button Content="← Volver al Dashboard" Command="{Binding GoBackCommand}"
                    Background="#757575" Foreground="White" Padding="15,8" BorderThickness="0" 
                    Cursor="Hand" HorizontalAlignment="Left" Margin="0,0,0,15" FontSize="13">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#616161"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Header -->
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <TextBlock Text="⚙️ Configuración del Sistema" FontSize="24" FontWeight="Bold" Foreground="#424242"/>
            </Border>

            <!-- Institution Settings -->
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🏫 Configuración Institucional" FontSize="18" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,15"/>
                    <TextBlock Text="Nombre de la Institución" FontWeight="SemiBold" Foreground="#424242" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding InstitutionName, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="10,8" FontSize="13" BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15"/>
                    <Button Content="💾 Guardar Configuración" Command="{Binding SaveSettingsCommand}"
                            Background="#4CAF50" Foreground="White" Padding="15,8" BorderThickness="0" 
                            Cursor="Hand" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Password Change -->
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🔒 Cambiar Contraseña" FontSize="18" FontWeight="Bold" Foreground="#FF9800" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Contraseña Actual" FontWeight="SemiBold" Foreground="#424242" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="CurrentPasswordBox" Padding="10,8" FontSize="13" 
                                BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15"
                                PasswordChanged="CurrentPasswordBox_PasswordChanged"/>
                    
                    <TextBlock Text="Nueva Contraseña" FontWeight="SemiBold" Foreground="#424242" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="NewPasswordBox" Padding="10,8" FontSize="13" 
                                BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15"
                                PasswordChanged="NewPasswordBox_PasswordChanged"/>
                    
                    <TextBlock Text="Confirmar Nueva Contraseña" FontWeight="SemiBold" Foreground="#424242" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" Padding="10,8" FontSize="13" 
                                BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15"
                                PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                    
                    <Button Content="🔑 Cambiar Contraseña" Command="{Binding ChangePasswordCommand}"
                            Background="#FF9800" Foreground="White" Padding="15,8" BorderThickness="0" 
                            Cursor="Hand" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Messages -->
            <TextBlock Text="{Binding SuccessMessage}" Foreground="#4CAF50" FontSize="13" 
                      TextWrapping="Wrap" Margin="0,0,0,10"
                      Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
            
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#F44336" FontSize="13" 
                      TextWrapping="Wrap" Margin="0,0,0,10"
                      Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
