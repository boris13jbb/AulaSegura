<UserControl x:Class="AulaSegura.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="920">
    <ScrollViewer Margin="20">
        <StackPanel>
            <Button Content="Volver al Dashboard"
                    Command="{Binding GoBackCommand}"
                    Background="#757575"
                    Foreground="White"
                    Padding="15,8"
                    BorderThickness="0"
                    Cursor="Hand"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,15"
                    FontSize="13"/>

            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <TextBlock Text="Configuracion del Sistema"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#424242"/>
            </Border>

            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Configuracion Institucional"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#2196F3"
                               Margin="0,0,0,15"/>
                    <TextBlock Text="Nombre de la Institucion"
                               FontWeight="SemiBold"
                               Foreground="#424242"
                               Margin="0,0,0,5"/>
                    <TextBox Text="{Binding InstitutionName, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8"
                             FontSize="13"
                             BorderBrush="#CCCCCC"
                             BorderThickness="1"
                             Margin="0,0,0,15"/>
                    <Button Content="Guardar Configuracion"
                            Command="{Binding SaveSettingsCommand}"
                            Background="#4CAF50"
                            Foreground="White"
                            Padding="15,8"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Cambiar Contrasena"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#FF9800"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="Contrasena Actual"
                               FontWeight="SemiBold"
                               Foreground="#424242"
                               Margin="0,0,0,5"/>
                    <PasswordBox x:Name="CurrentPasswordBox"
                                 Padding="10,8"
                                 FontSize="13"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 Margin="0,0,0,15"
                                 PasswordChanged="CurrentPasswordBox_PasswordChanged"/>

                    <TextBlock Text="Nueva Contrasena"
                               FontWeight="SemiBold"
                               Foreground="#424242"
                               Margin="0,0,0,5"/>
                    <PasswordBox x:Name="NewPasswordBox"
                                 Padding="10,8"
                                 FontSize="13"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 Margin="0,0,0,15"
                                 PasswordChanged="NewPasswordBox_PasswordChanged"/>

                    <TextBlock Text="Confirmar Nueva Contrasena"
                               FontWeight="SemiBold"
                               Foreground="#424242"
                               Margin="0,0,0,5"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Padding="10,8"
                                 FontSize="13"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 Margin="0,0,0,15"
                                 PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                    <Button Content="Cambiar Contrasena"
                            Command="{Binding ChangePasswordCommand}"
                            Background="#FF9800"
                            Foreground="White"
                            Padding="15,8"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Respaldos y Restauracion"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#607D8B"
                               Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding BackupDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8"
                                 FontSize="13"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"/>
                        <Button Grid.Column="2"
                                Content="Crear Respaldo"
                                Command="{Binding CreateBackupCommand}"
                                Background="#607D8B"
                                Foreground="White"
                                Padding="15,8"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </Grid>

                    <ListView ItemsSource="{Binding Backups}"
                              SelectedItem="{Binding SelectedBackup}"
                              MinHeight="140"
                              MaxHeight="240"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Fecha"
                                                Width="150"
                                                DisplayMemberBinding="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}"/>
                                <GridViewColumn Header="Descripcion"
                                                Width="260"
                                                DisplayMemberBinding="{Binding Description}"/>
                                <GridViewColumn Header="Tipo"
                                                Width="90"
                                                DisplayMemberBinding="{Binding BackupType}"/>
                                <GridViewColumn Header="Tamano"
                                                Width="90"
                                                DisplayMemberBinding="{Binding SizeInBytes}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <Button Content="Restaurar Seleccionado"
                                Command="{Binding RestoreBackupCommand}"
                                Background="#2196F3"
                                Foreground="White"
                                Padding="15,8"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,10,0"/>
                        <Button Content="Eliminar de la Lista"
                                Command="{Binding DeleteBackupCommand}"
                                Background="#D32F2F"
                                Foreground="White"
                                Padding="15,8"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,10,0"/>
                        <Button Content="Actualizar"
                                Command="{Binding LoadBackupsCommand}"
                                Background="#757575"
                                Foreground="White"
                                Padding="15,8"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding SuccessMessage}"
                       Foreground="#4CAF50"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"
                       Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#F44336"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
