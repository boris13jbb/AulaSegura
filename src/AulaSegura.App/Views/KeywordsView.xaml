<UserControl x:Class="AulaSegura.App.Views.KeywordsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2196F3" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Back Button -->
                <Button Grid.Column="0"
                        Content="← Volver"
                        Command="{Binding GoBackCommand}"
                        Background="Transparent"
                        Foreground="White"
                        FontWeight="Bold"
                        Padding="12,8"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="14"
                        Margin="0,0,15,0"/>
                
                <StackPanel Grid.Column="1">
                    <TextBlock Text=" Gestión de Palabras Clave" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="Administre las palabras clave para detección de contenido" 
                               FontSize="14" 
                               Foreground="#E3F2FD"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Add New Keyword Section -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="➕ Agregar Nueva Palabra Clave" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="#424242"
                           Margin="0,0,0,15"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                    </Grid.RowDefinitions>

                    <TextBox Grid.Column="0" 
                             Text="{Binding NewKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8"
                             FontSize="13"
                             BorderBrush="#BDBDBD"
                             BorderThickness="1"
                             VerticalContentAlignment="Center">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <ComboBox Grid.Column="1" 
                              SelectedItem="{Binding SelectedType}"
                              Padding="10,8"
                              FontSize="13"
                              BorderBrush="#BDBDBD"
                              BorderThickness="1"
                              Margin="10,0,0,0">
                        <ComboBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </ComboBox.Resources>
                        <ComboBoxItem Content="Bloqueada" Tag="Blocked"/>
                        <ComboBoxItem Content="Permitida" Tag="Allowed"/>
                    </ComboBox>

                    <Button Grid.Column="2" 
                            Content="Agregar" 
                            Command="{Binding AddKeywordCommand}"
                            Background="#4CAF50"
                            Foreground="White"
                            Padding="20,8"
                            Margin="10,0,0,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="Guardar"
                                Command="{Binding UpdateKeywordCommand}"
                                Background="#2196F3"
                                Foreground="White"
                                Padding="20,8"
                                Margin="10,0,5,0"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="13">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Cancelar"
                                Command="{Binding CancelEditCommand}"
                                Background="#757575"
                                Foreground="White"
                                Padding="20,8"
                                Margin="5,0,0,0"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="13">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Keywords List -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="📋 Lista de Palabras Clave" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="#424242"
                           Margin="0,0,0,15"/>

                <ListView Grid.Row="1" 
                          ItemsSource="{Binding Keywords}"
                          BorderThickness="0"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="15" Margin="0,0,0,8" Background="#FAFAFA" CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Word}" 
                                                   FontSize="14" 
                                                   FontWeight="SemiBold"
                                                   Foreground="#424242"/>
                                        <TextBlock Text="{Binding Type, StringFormat='Tipo: {0}'}" 
                                                   FontSize="11" 
                                                   Foreground="#757575"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding IsActive, StringFormat='Activa: {0}'}"
                                               FontSize="11"
                                               Foreground="#4CAF50"
                                               VerticalAlignment="Center"
                                               Margin="0,0,15,0"/>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Content="✏️ Editar"
                                                Command="{Binding DataContext.EditKeywordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="#FF9800"
                                                Foreground="White"
                                                Padding="12,6"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                FontSize="11"
                                                Margin="0,0,8,0"/>
                                        <Button Content="🗑️ Eliminar"
                                                Command="{Binding DataContext.DeleteKeywordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="#F44336"
                                                Foreground="White"
                                                Padding="12,6"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                FontSize="11"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#E3F2FD" CornerRadius="4" Padding="15" Margin="0,20,0,0">
            <TextBlock Text="{Binding StatusMessage}" 
                       FontSize="12" 
                       Foreground="#1976D2"/>
        </Border>
    </Grid>
</UserControl>
