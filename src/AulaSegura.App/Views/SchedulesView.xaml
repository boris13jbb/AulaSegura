<UserControl x:Class="AulaSegura.App.Views.SchedulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0"
                Content="Volver al Dashboard"
                Command="{Binding GoBackCommand}"
                Background="#757575"
                Foreground="White"
                Padding="15,8"
                BorderThickness="0"
                Cursor="Hand"
                HorizontalAlignment="Left"
                Margin="0,0,0,15"
                FontSize="13"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Gestion de Horarios"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#424242"/>
                    <TextBlock Text="Configure ventanas de bloqueo por dia y categoria"
                               FontSize="12"
                               Foreground="#757575"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Agregar Horario"
                        Command="{Binding AddNewCommand}"
                        Background="#2196F3"
                        Foreground="White"
                        Padding="15,8"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,15"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="Formulario de Horario"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#424242"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Nombre"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#616161"
                           Margin="0,0,0,5"/>
                <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10,8"
                         FontSize="13"
                         BorderBrush="#CCCCCC"
                         BorderThickness="1"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Dia de la Semana"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#616161"
                           Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding AvailableDays}"
                          SelectedItem="{Binding FormDayOfWeek, UpdateSourceTrigger=PropertyChanged}"
                          Padding="10,8"
                          FontSize="13"
                          BorderBrush="#CCCCCC"
                          BorderThickness="1"
                          Margin="0,0,0,15"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Hora de Inicio"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#616161"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding FormStartTime, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8"
                                 FontSize="13"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 ToolTip="Formato: HH:MM, por ejemplo 08:00"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Hora de Fin"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#616161"
                                   Margin="0,0,0,5"/>
                        <TextBox Text="{Binding FormEndTime, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8"
                                 FontSize="13"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 ToolTip="Formato: HH:MM, por ejemplo 15:00"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Categoria"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#616161"
                           Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Categories}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding FormCategoryId, UpdateSourceTrigger=PropertyChanged}"
                          Padding="10,8"
                          FontSize="13"
                          BorderBrush="#CCCCCC"
                          BorderThickness="1"
                          Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Guardar"
                            Command="{Binding SaveCommand}"
                            Background="#2196F3"
                            Foreground="White"
                            Padding="15,8"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            Margin="0,0,10,0"/>
                    <Button Content="Cancelar"
                            Command="{Binding CancelCommand}"
                            Background="#757575"
                            Foreground="White"
                            Padding="15,8"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
            <DataGrid ItemsSource="{Binding Schedules}"
                      SelectedItem="{Binding SelectedSchedule}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Dia" Binding="{Binding DayOfWeek}" Width="100"/>
                    <DataGridTextColumn Header="Inicio" Binding="{Binding StartTime, StringFormat={}{0:hh\\:mm}}" Width="80"/>
                    <DataGridTextColumn Header="Fin" Binding="{Binding EndTime, StringFormat={}{0:hh\\:mm}}" Width="80"/>
                    <DataGridTextColumn Header="Categoria" Binding="{Binding Category.Name}" Width="*"/>
                    <DataGridTemplateColumn Header="Acciones" Width="170">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Editar"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="#FF9800"
                                            Foreground="White"
                                            Padding="8,5"
                                            Margin="0,0,5,0"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="11"/>
                                    <Button Content="Eliminar"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="#F44336"
                                            Foreground="White"
                                            Padding="8,5"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="4"
                   Text="{Binding ErrorMessage}"
                   Foreground="#F44336"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
    </Grid>
</UserControl>
