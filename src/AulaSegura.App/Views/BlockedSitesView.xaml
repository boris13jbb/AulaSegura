<UserControl x:Class="AulaSegura.App.Views.BlockedSitesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    
    <UserControl.Resources>
        <!-- Button Styles -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDBDBD"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#388E3C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Back Button -->
        <Button Grid.Row="0" Content="← Volver al Dashboard" Command="{Binding GoBackCommand}"
                Background="#757575" Foreground="White" Padding="15,8" BorderThickness="0" 
                Cursor="Hand" HorizontalAlignment="Left" Margin="0,0,0,15" FontSize="13">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#616161"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- Header and Actions -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🚫 Gestión de Sitios Bloqueados" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="#424242"/>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#757575"
                               Margin="0,5,0,0"
                               MaxWidth="700"
                               LineHeight="18"
                               Text="Si escribe www.facebook.com se guardará como facebook.com (normalizado). Para quitar la redirección local al archivo hosts el programa debe ejecutarse como administrador (o usar «Aplicar reglas» con permisos elevados). Si el servicio AulaSegura está instalado, también puede sincronizar el hosts periódicamente."/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="➕ Agregar Sitio" 
                            Command="{Binding AddNewCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,10,0"/>
                    <Button Content="🔄 Aplicar Reglas" 
                            Command="{Binding ApplyRulesCommand}"
                            Style="{StaticResource SuccessButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Add/Edit Form -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="{Binding IsEditMode, Converter={StaticResource BoolToStringConverter}, ConverterParameter='✏️ Editar Sitio|➕ Agregar Nuevo Sitio'}" 
                           FontSize="18" FontWeight="Bold" Foreground="#424242" Margin="0,0,0,15"/>

                <TextBlock Text="Dominio:" FontSize="13" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,5"/>
                <TextBox Text="{Binding FormDomain, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="10,8" FontSize="13" BorderBrush="#CCCCCC" BorderThickness="1" 
                         Margin="0,0,0,15" ToolTip="Ejemplo: facebook.com"/>

                <TextBlock Text="Motivo:" FontSize="13" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,5"/>
                <TextBox Text="{Binding FormReason, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="10,8" FontSize="13" BorderBrush="#CCCCCC" BorderThickness="1" 
                         Margin="0,0,0,15" AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                         ToolTip="Razón del bloqueo"/>

                <TextBlock Text="Categoría:" FontSize="13" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Categories}" 
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding FormCategoryId, UpdateSourceTrigger=PropertyChanged}"
                          Padding="10,8" FontSize="13" BorderBrush="#CCCCCC" BorderThickness="1" 
                          Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="💾 Guardar" 
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,10,0"/>
                    <Button Content="❌ Cancelar" 
                            Command="{Binding CancelCommand}"
                            Background="#757575" Foreground="White" Padding="15,8" 
                            BorderThickness="0" Cursor="Hand" FontSize="13">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#616161"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Search (fila compacta; el * debe estar en la tabla, no aquí) -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <Grid VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center"
                         MinHeight="38"
                         MaxHeight="40"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10,8"
                         FontSize="13"
                         BorderBrush="#CCCCCC"
                         BorderThickness="1"
                         ToolTip="Buscar por dominio o razón">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        Content="🔍 Buscar"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="10,0,0,0"
                        Padding="16,8"
                        MinHeight="38"/>
                <CheckBox Grid.Column="2"
                          VerticalAlignment="Center"
                          Margin="14,0,0,0"
                          FontSize="12"
                          FontWeight="SemiBold"
                          Foreground="#424242"
                          Content="Mostrar también desactivados"
                          ToolTip="Muestra entradas con bloqueo desactivado (p. ej. para volver a activar sin crear duplicados)."
                          IsChecked="{Binding ShowInactiveBlockedSites, Mode=TwoWay}"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="4" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10" VerticalAlignment="Stretch">
            <DataGrid ItemsSource="{Binding BlockedSites}"
                      SelectedItem="{Binding SelectedSite}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      FontSize="13"
                      VerticalAlignment="Stretch"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                
                <DataGrid.Columns>
                    <!-- Domain Column -->
                    <DataGridTextColumn Header="Dominio" 
                                       Binding="{Binding Domain}"
                                       Width="2*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="5,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Category Column -->
                    <DataGridTextColumn Header="Categoría" 
                                       Binding="{Binding Category.Name}"
                                       Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="5,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Reason Column -->
                    <DataGridTextColumn Header="Motivo" 
                                       Binding="{Binding Reason}"
                                       Width="2*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="5,0"/>
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Estado: texto + acción para activar/desactivar (antes solo era lectura) -->
                    <DataGridTemplateColumn Header="Estado" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding IsActive, Converter={StaticResource BoolToStringConverter}, ConverterParameter='✅ Activo|❌ Inactivo'}"
                                               VerticalAlignment="Center"
                                               Padding="5,0,8,0"/>
                                    <Button Content="{Binding IsActive, Converter={StaticResource BoolToStringConverter}, ConverterParameter='⏸️ Desactivar|▶️ Activar'}"
                                            Command="{Binding DataContext.ToggleActiveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="#9C27B0"
                                            Foreground="White"
                                            Padding="8,5"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Actions Column -->
                    <DataGridTemplateColumn Header="Acciones" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="✏️ Editar"
                                           Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           CommandParameter="{Binding}"
                                           Background="#FF9800"
                                           Foreground="White"
                                           Padding="8,5"
                                           Margin="0,0,5,0"
                                           BorderThickness="0"
                                           Cursor="Hand"
                                           FontSize="11"/>
                                    <Button Content="🗑️ Eliminar"
                                           Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           CommandParameter="{Binding}"
                                           Background="#F44336"
                                           Foreground="White"
                                           Padding="8,5"
                                           BorderThickness="0"
                                           Cursor="Hand"
                                           FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Error Message -->
        <TextBlock Grid.Row="5"
                   Text="{Binding ErrorMessage}"
                   Foreground="#F44336"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
    </Grid>
</UserControl>
