<UserControl x:Class="AulaSegura.App.Views.BlockingRulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#FF9800" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Back Button -->
                <Button Grid.Column="0"
                        Content="← Volver"
                        Command="{Binding GoBackCommand}"
                        Background="Transparent"
                        Foreground="White"
                        FontWeight="Bold"
                        Padding="12,8"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="14"
                        Margin="0,0,15,0"/>
                
                <StackPanel Grid.Column="1">
                    <TextBlock Text="️ Reglas de Bloqueo Automático" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Configure reglas para bloqueo automático basado en violaciones" FontSize="14" Foreground="#FFF3E0" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="➕ Crear Nueva Regla" FontSize="16" FontWeight="Bold" Foreground="#424242" Margin="0,0,0,15"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewRuleName, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" FontSize="13" BorderBrush="#BDBDBD" BorderThickness="1"/>
                    <ComboBox Grid.Column="2" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Name" Padding="10,8" FontSize="13" BorderBrush="#BDBDBD" BorderThickness="1"/>
                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <TextBlock Text="Máx:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="12"/>
                        <TextBox Text="{Binding MaxViolations}" Width="50" Padding="5,8" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6" Orientation="Horizontal">
                        <TextBlock Text="Min:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="12"/>
                        <TextBox Text="{Binding BlockDurationMinutes}" Width="50" Padding="5,8" FontSize="13"/>
                    </StackPanel>
                    <Button Grid.Column="8" Content="Crear" Command="{Binding AddRuleCommand}" Background="#FF9800" Foreground="White" Padding="20,8" BorderThickness="0" Cursor="Hand" FontSize="13">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <StackPanel Grid.Column="8" Orientation="Horizontal">
                        <Button Content="Guardar"
                                Command="{Binding UpdateRuleCommand}"
                                Background="#2196F3"
                                Foreground="White"
                                Padding="20,8"
                                Margin="0,0,5,0"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="13">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Cancelar"
                                Command="{Binding CancelEditCommand}"
                                Background="#757575"
                                Foreground="White"
                                Padding="20,8"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="13">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20">
            <ListView ItemsSource="{Binding Rules}" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="15" Margin="0,0,0,8" Background="#FAFAFA" CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding Category.Name}" FontSize="11" Foreground="#757575"/>
                                <TextBlock Grid.Column="2" Text="{Binding MaxViolations, StringFormat='Máx: {0}'}" FontSize="11" Foreground="#F44336"/>
                                <TextBlock Grid.Column="3" Text="{Binding BlockDurationMinutes, StringFormat='{}{0} min'}" FontSize="11" Foreground="#FF9800"/>
                                <StackPanel Grid.Column="4" Orientation="Horizontal">
                                    <Button Content="✏️"
                                            Command="{Binding DataContext.EditRuleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            Foreground="#FF9800"
                                            Padding="8,4"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Margin="0,0,5,0"/>
                                    <Button Content="🗑️"
                                            Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            Foreground="#F44336"
                                            Padding="8,4"
                                            BorderThickness="0"
                                            Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
        <Border Grid.Row="3" Background="#FFF3E0" CornerRadius="4" Padding="15" Margin="0,20,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#E65100"/>
        </Border>
    </Grid>
</UserControl>
